# Google Gemini API key (optional fallback for client-side analysis)
GEMINI_API_KEY=

# PayPal client ID (optional, defaults to "sb" sandbox when unset)
VITE_PAYPAL_CLIENT_ID=

# OpenRouter API key for /api/analyze (set either variable name)
APEX_INNOVATE_API=
OPENROUTER_API_KEY=

# Public app URL used for OpenRouter HTTP-Referer (optional)
APP_URL=
