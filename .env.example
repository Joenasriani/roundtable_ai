# Server-side OpenRouter key for /api/analyze
OPENROUTER_API_KEY=

# Optional legacy key name still supported by the server
APEX_INNOVATE_API=

# OpenRouter model routing
OPENROUTER_DEFAULT_MODEL=
OPENROUTER_FALLBACK_MODEL=

# Public app URL used in OpenRouter headers
APP_URL=

# Optional client-side Gemini key for BYO-key mode
GEMINI_API_KEY=

# PayPal client id for checkout UI
VITE_PAYPAL_CLIENT_ID=
