# .env.example
# Google Gemini API Key (Required for client-side fallback)
GEMINI_API_KEY=
# PayPal Client ID (Get from developer.paypal.com - Required for $1 sessions)
# Use 'sb' for local testing
VITE_PAYPAL_CLIENT_ID=
# OpenRouter API Key (Server-side proxy)
OPENROUTER_API_KEY=
# Legacy alias supported by the app
APEX_INNOVATE_API=
# OpenRouter API base URL and timeout (optional)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=45000
# Model selection (optional)
OPENROUTER_DEFAULT_MODEL=
OPENROUTER_FALLBACK_MODEL=
# Alternative aliases accepted by the app
AI_MODEL=
TEXT_MODEL=
RESEARCH_MODEL=
# App URL (optional - used as OpenRouter referer)
APP_URL=
