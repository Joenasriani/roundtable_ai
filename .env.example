# .env.example
# Google Gemini API Key (Required for client-side fallback)
GEMINI_API_KEY=
# PayPal Client ID (Get from developer.paypal.com - Required for $1 sessions)
# Use 'sb' for local testing
VITE_PAYPAL_CLIENT_ID=
# OpenRouter API Key (Optional - Enables server-side proxy to free models)
APEX_INNOVATE_API=
# App URL (Optional - Helping with OpenRouter referer check)
APP_URL=
